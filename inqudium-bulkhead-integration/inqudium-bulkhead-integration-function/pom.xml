<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>eu.inqudium</groupId>
        <artifactId>inqudium-bulkhead-integration</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>inqudium-bulkhead-integration-function</artifactId>
    <name>Inqudium :: Bulkhead :: Integration Example :: Function</name>
    <description>
        Function-based bulkhead integration example — no framework, no DI, no AspectJ.
        Demonstrates the canonical Inqudium function-decoration pattern against a tiny
        webshop OrderService.
    </description>

    <dependencies>

        <!-- ========================= -->
        <!--  Modules under demonstration -->
        <!-- ========================= -->
        <dependency>
            <groupId>eu.inqudium</groupId>
            <artifactId>inqudium-core</artifactId>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>eu.inqudium</groupId>
            <artifactId>inqudium-config</artifactId>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>eu.inqudium</groupId>
            <artifactId>inqudium-imperative</artifactId>
            <scope>compile</scope>
        </dependency>

        <!-- ========================= -->
        <!--  Logging                  -->
        <!-- ========================= -->
        <!--
             Practice-grade logging stack used by the example: SLF4J as the
             compile-time API, Logback as the runtime implementation.
             logback-classic is referenced exclusively from
             src/main/resources/logback.xml — never from source — so it lives
             in scope=runtime. SLF4J's binding mechanism picks it up off the
             runtime classpath at the first LoggerFactory call.
        -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- JUnit 5 + AssertJ are inherited as test-scope from the root parent POM. -->

    </dependencies>

</project>
